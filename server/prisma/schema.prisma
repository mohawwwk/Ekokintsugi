generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  name           String
  phone          String
  email          String    @unique
  password       String
  role           String    @default("supporter")
  city           String?
  address        String?
  shoeSize       String?
  startDate      DateTime?
  endDate        DateTime?
  qrCode         String?
  pointsTotal    Int       @default(0)
  pointsUsed     Int       @default(0)
  pointsRemaining Int      @default(0)
  shoe           Shoe?
  tree           Tree?
  reviews        Review[]
  returns        Return[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Shoe {
  id          String   @id @default(uuid())
  shoeId      String   @unique
  productLine String
  size        String
  status      String   @default("PreBooked")
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])
  returns     Return[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tree {
  id        String   @id @default(uuid())
  treeId    String   @unique
  plantType String
  location  String
  status    String   @default("Symbolic Tree Parent")
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  weekNumber  Int
  daysWorn    Int
  hoursPerDay Int
  comfort     Int
  fit         Int
  sole        Int
  material    Int
  stitching   Int
  feedback    String?
  image       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, weekNumber])
}

model Return {
  id          String   @id @default(uuid())
  userId      String
  shoeId      String
  reason      String
  condition   String
  status      String   @default("Requested")
  finalAction String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  shoe        Shoe     @relation(fields: [shoeId], references: [id])
}
